PORT=5000
NODE_ENV=development

# In Railway, these are set via reference variables pointing to the Postgres service.
# See railway.toml for the production values. For local development, fill in your own.
DB_HOST=localhost
DB_PORT=5432
DB_NAME=filling_station_db
DB_USER=postgres
DB_PASSWORD=your_local_password_here
DB_LOGGING=false
JWT_SECRET=your_local_jwt_secret_here
JWT_EXPIRES_IN=1d
